# Active Spring profile: local, dev, prod, test
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/arenax
DATABASE_USERNAME=arenax
DATABASE_PASSWORD=arenax_dev_password

# JPA
JPA_SHOW_SQL=true

# JWT
JWT_SECRET=arenax-local-development-jwt-secret-key-please-change
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
